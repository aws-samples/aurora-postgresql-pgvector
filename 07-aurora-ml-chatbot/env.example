# Copy this file to .env and replace every value — angle-bracket placeholders
# like <username> are NOT valid; they must be replaced with real values.
POSTGRESQL_ENDPOINT="auroraml-bedrock-1.cluster-XXXXXX.us-west-2.rds.amazonaws.com"
POSTGRESQL_PORT="5432"
POSTGRESQL_USER="<username>"
POSTGRESQL_PW="<password>"
POSTGRESQL_DBNAME="<dbname>"
REGION="us-west-2"
SOURCE_S3_BUCKET="<knowledge-dataset-bucket-name>"
# Generation model — global cross-region inference profile (verified working).
# Override with global.anthropic.claude-sonnet-5 for the latest model.
BEDROCK_MODEL_ID="global.anthropic.claude-sonnet-5"
# Embeddings — Titan Embeddings V2 at 1024 dimensions (verified working).
EMBEDDING_MODEL_ID="amazon.titan-embed-text-v2:0"
