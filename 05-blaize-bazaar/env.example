# Aurora PostgreSQL connection
DB_HOST=<aurora-cluster-endpoint>
DB_PORT=5432
DB_NAME=postgres
DB_USER=<database-username>
DB_PASSWORD=<database-password>

# AWS region — defaults to us-west-2 when unset
AWS_REGION=us-west-2

# Bedrock generation model
# Default: global.anthropic.claude-sonnet-5 (cross-region inference profile, verified 2026-07)
# Override example: global.anthropic.claude-sonnet-5
BEDROCK_CLAUDE_MODEL_ID=global.anthropic.claude-sonnet-5

# Bedrock Knowledge Base ID (used by page 3 — Query Bedrock Knowledge Base)
BEDROCK_KB_ID=<knowledge-base-id>

# Bedrock Agent ID and Alias ID (used by page 4 — Bedrock Agents)
BEDROCK_AGENT_ID=<agent-id>
BEDROCK_AGENT_ALIAS_ID=<agent-alias-id>

# S3 bucket that backs the Knowledge Base (used by page 3 delete/re-sync)
S3_KB_BUCKET=<knowledge-base-s3-bucket-name>

# Lambda function name that triggers KB re-ingestion after S3 changes
LAMBDA_FUNCTION_NAME=genai-dat-301-labs_BedrockAgent_Lambda
